<Window x:Class="ProgressBarT3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProgressBarT3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBlock HorizontalAlignment="Center" Margin="0,35,0,0" TextWrapping="Wrap" Text="Кількість чисел фібоначі" VerticalAlignment="Top" Height="45" Width="292" FontSize="22"/>
        <TextBox HorizontalAlignment="Left" Margin="254,139,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="159" Height="31" FontSize="16" Name="FibonacciCountTextBox"/>
        <TextBox HorizontalAlignment="Left" Margin="26,139,0,0" TextWrapping="Wrap" Text="Введіть верхню межу: " VerticalAlignment="Top" Width="204" FontSize="16" RenderTransformOrigin="0.5,0.5" Height="26">
            <TextBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.607"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.636"/>
                </TransformGroup>
            </TextBox.RenderTransform>
        </TextBox>
        <TextBox HorizontalAlignment="Left" Margin="26,196,0,0" TextWrapping="Wrap" Text="Кількість чисел фібоначі:  " VerticalAlignment="Top" Width="204" FontSize="16" RenderTransformOrigin="0.5,0.5" Height="26">
            <TextBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.607"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.636"/>
                </TransformGroup>
            </TextBox.RenderTransform>
        </TextBox>
        <TextBox HorizontalAlignment="Left" Margin="257,196,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="204" FontSize="16" RenderTransformOrigin="0.5,0.5" Height="26" Name="res">
            <TextBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.607"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.636"/>
                </TransformGroup>
            </TextBox.RenderTransform>
        </TextBox>
        <Button Content="Обчислити" HorizontalAlignment="Left" Margin="597,137,0,0" VerticalAlignment="Top" Height="35" Width="113" Click="Button_Click"/>

    </Grid>
</Window>
