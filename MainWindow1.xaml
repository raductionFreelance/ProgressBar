<Window x:Class="ProgressBars.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProgressBars"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="0,0,0,-16">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="10,0,0,225">
            <StackPanel Margin="330,0,0,225">

                <StackPanel x:Name="ProgressBarContainer" Margin="20"/>
            </StackPanel>
        </ScrollViewer>
        <Button Content="2" Margin="10,51,590,349" FontSize="16" Click="Button_Click1"/>
        <Button Content="3" Margin="10,109,590,291" FontSize="16" Click="Button_Click2"/>
        <Button Content="0" Margin="10,165,590,235" FontSize="16" Click="Button_Click3"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" Text="Завдання №1" VerticalAlignment="Top" Height="36" Width="161" FontSize="22"/>
        <ProgressBar HorizontalAlignment="Left" Height="26" Margin="10,225,0,0" VerticalAlignment="Top" Width="262" x:Name="Hourse1" Minimum="0" Maximum="100" Value="0" Foreground="Aqua"/>
        <ProgressBar HorizontalAlignment="Left" Height="26" Margin="10,256,0,0" VerticalAlignment="Top" Width="262" x:Name="Hourse2" Minimum="0" Maximum="100" Value="0" Foreground="Azure"/>
        <ProgressBar HorizontalAlignment="Left" Height="26" Margin="10,302,0,0" VerticalAlignment="Top" Width="262" x:Name="Hourse3" Minimum="0" Maximum="100" Value="0" Foreground="Bisque"/>
        <ProgressBar HorizontalAlignment="Left" Height="26" Margin="10,346,0,0" VerticalAlignment="Top" Width="262" x:Name="Hourse4" Minimum="0" Maximum="100" Value="0" Foreground="BlueViolet"/>
        <ProgressBar HorizontalAlignment="Left" Height="26" Margin="10,394,0,0" VerticalAlignment="Top" Width="262" x:Name="Hourse5" Minimum="0" Maximum="100" Value="0" Foreground="Brown"/>
        <Button Content="Start" Margin="560,230,40,170" FontSize="16" Click="Start"/>

    </Grid>
</Window>
